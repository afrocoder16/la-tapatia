# Square checkout backend — environment variables.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# "sandbox" for testing, "production" when going live.
SQUARE_ENVIRONMENT=sandbox

# Square Access Token (Sandbox token for sandbox, Production token for production).
# Get it from https://developer.squareup.com/apps -> your app -> Credentials.
SQUARE_ACCESS_TOKEN=your-sandbox-access-token-here

# The Square Location ID that receives the orders.
# Run `npm run location` once to list your locations and copy the ID here.
SQUARE_LOCATION_ID=your-location-id-here

# Where Square sends the customer back after paying (a page on your site).
# For local testing this is the static site served by http.server.
CHECKOUT_REDIRECT_URL=http://localhost:8000/?checkout=success

# Comma-separated list of origins allowed to call this API (CORS).
# Add your production domain here when you deploy.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8123

# Port for this server.
PORT=4242
